# NOTE: Vercel applies this repo-root .vercelignore to BOTH projects
# built from this repo (the serverless API at the root, and the web at
# apps/web). So it must NOT exclude apps/web -- doing so deletes the web
# project's own source. Everything listed here is unused by both builds.
apps/api
agents
docs
tests
packages
.github
supabase
ml/training/data
ml/training/reports
Dockerfile
.dockerignore
