# Copy this file to .env and paste your real keys. NEVER commit .env.

# Create a key at https://console.anthropic.com/ (Settings > API Keys).
ANTHROPIC_API_KEY=your-key-here

# Only needed with --sink supabase: mirrors collected listings into the
# shared Postgres. Use the service_role key (Supabase dashboard >
# Project Settings > API keys), NOT the publishable key -- the listings
# table has no RLS policies and only the service role can write to it.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
